# Frontend — URLs de los microservicios
# - Desarrollo: copia este archivo a `.env` en esta carpeta (Vite lo carga siempre; el proxy usa
#   esas URLs). Si no existe `.env`, el proxy usa http://localhost:5001…5005.
# - Producción (`vite build`): define VITE_MS*_URL en `.env.production` o en el CI (obligatorio en
#   el bundle; en `api.ts` no hay fallback a localhost).

VITE_MS1_URL=http://localhost:5001
VITE_MS2_URL=http://localhost:5002
VITE_MS3_URL=http://localhost:5003
VITE_MS4_URL=http://localhost:5004
VITE_MS5_URL=http://localhost:5005

# Opcional: enlace del icono GitHub en el navbar del landing (por defecto https://github.com)
# VITE_GITHUB_URL=https://github.com/tu-usuario/FinTrend
